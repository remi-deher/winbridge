<Window
    x:Class="WinBridge.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="WinBridge - Admin Linux">

    <NavigationView x:Name="NavView" 
                    PaneDisplayMode="Left"
                    IsSettingsVisible="True">
        <NavigationView.MenuItems>
            <NavigationViewItem Content="Tableau de bord" Icon="Home" Tag="Dashboard"/>
            <NavigationViewItem Content="Serveurs" Icon="AllApps" Tag="Servers"/>
            <NavigationViewItem Content="Gestion des Clés" Icon="Permissions" Tag="Keys"/>
            <NavigationViewItemSeparator/>
            <NavigationViewItem Content="Extensions" Icon="Library" Tag="Extensions"/>
            <NavigationViewItem Content="Configuration Modules" Icon="Manage" Tag="ModulesManagement"/>
        </NavigationView.MenuItems>

        <NavigationView.FooterMenuItems>
            <NavigationViewItem Content="Mode Développeur" Tag="DevTools">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE943;"/>
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.FooterMenuItems>

        <Frame x:Name="ContentFrame"/>
    </NavigationView>
</Window>