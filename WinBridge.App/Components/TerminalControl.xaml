<UserControl
    x:Class="WinBridge.App.Components.TerminalControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <WebView2 x:Name="TermWebView" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>

        <Button x:Name="BtnExpand" 
                Click="BtnExpand_Click"
                HorizontalAlignment="Right" VerticalAlignment="Top" 
                Margin="0,10,20,0" Padding="6"
                Background="{ThemeResource LayerFillColorDefaultBrush}" Opacity="0.6"
                ToolTipService.ToolTip="Plein Écran">
            <SymbolIcon x:Name="IconExpand" Symbol="FullScreen"/>
        </Button>
    </Grid>
</UserControl>