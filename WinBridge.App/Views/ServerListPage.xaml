<Page
    x:Class="WinBridge.App.Views.ServerListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WinBridge.Models.Entities"
    mc:Ignorable="d"
    NavigationCacheMode="Required">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="48,32,48,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock Text="Serveurs" Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock Text="Gérez vos connexions SSH" Style="{StaticResource BodyTextBlockStyle}" Opacity="0.6"/>
            </StackPanel>
            <Button Grid.Column="1" Click="BtnAddServer_Click" Style="{StaticResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    <TextBlock Text="Nouveau Serveur"/>
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="1" Padding="48,0,48,48">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="TxtSearch" Grid.Column="0" PlaceholderText="Rechercher (Nom, IP...)" 
                         TextChanged="OnFilterChanged" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBox.Header>
                        <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,0,4">
                            <FontIcon Glyph="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                            <TextBlock Text="Rechercher" FontSize="12"/>
                        </StackPanel>
                    </TextBox.Header>
                </TextBox>

                <ComboBox x:Name="CmbOsFilter" Grid.Column="1" Header="Filtrer par OS" 
                          SelectionChanged="OnFilterChanged" SelectedIndex="0" 
                          HorizontalAlignment="Stretch" VerticalAlignment="Center">

                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="MinHeight" Value="32"/>
                        </Style>
                    </ComboBox.ItemContainerStyle>

                    <ComboBoxItem Content="Tous les serveurs" Tag="All"/>
                    <ComboBoxItem Content="Linux (Tous)" Tag="Linux"/>
                    <ComboBoxItem Content="Windows (Tous)" Tag="Windows"/>
                    <ComboBoxItem Content="Debian" Tag="Debian"/>
                    <ComboBoxItem Content="Ubuntu" Tag="Ubuntu"/>
                    <ComboBoxItem Content="CentOS / Alma / Rocky" Tag="CentOS"/>
                    <ComboBoxItem Content="Arch Linux" Tag="Arch"/>
                </ComboBox>
            </Grid>

            <ScrollViewer Grid.Row="1">
                <StackPanel>
                    <TextBlock x:Name="TxtEmpty" Text="Aucun serveur trouvé." 
                               HorizontalAlignment="Center" Margin="0,60,0,0" Opacity="0.5" Visibility="Collapsed"/>

                    <GridView x:Name="ServerGrid" SelectionMode="None">
                        <GridView.ItemContainerStyle>
                            <Style TargetType="GridViewItem">
                                <Setter Property="Margin" Value="0,0,16,16"/>
                            </Style>
                        </GridView.ItemContainerStyle>
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="models:ServerModel">
                                <Grid Width="280" Height="140" Background="{ThemeResource LayerFillColorDefaultBrush}" 
                                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" 
                                      CornerRadius="8" Padding="20">

                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Grid Grid.Column="0" HorizontalAlignment="Left" Width="40" Height="40" CornerRadius="20" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                                            <FontIcon Glyph="&#xE7F8;" FontFamily="Segoe MDL2 Assets" FontSize="18"/>
                                        </Grid>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                            <Button Click="BtnEdit_Click" ToolTipService.ToolTip="Modifier" Padding="6" Background="Transparent" BorderThickness="0">
                                                <FontIcon Glyph="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="14" Opacity="0.6"/>
                                            </Button>
                                            <Button Click="BtnDelete_Click" ToolTipService.ToolTip="Supprimer" Padding="6" Background="Transparent" BorderThickness="0">
                                                <FontIcon Glyph="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#D13438"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Grid.Row="1" Margin="0,12,0,0" Spacing="2">
                                        <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" FontSize="16" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{x:Bind Host}" Opacity="0.6" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{x:Bind CachedOsInfo, TargetNullValue='OS Inconnu'}" Opacity="0.4" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <Button Grid.Row="2" Click="BtnConnect_Click" HorizontalAlignment="Stretch" Margin="0,12,0,0">
                                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                            <FontIcon Glyph="&#xE7F4;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                                            <TextBlock Text="Connecter"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>