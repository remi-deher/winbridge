<Page
    x:Class="WinBridge.App.Views.ServerListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WinBridge.Models.Entities"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Padding="24" Orientation="Horizontal" Spacing="20">
            <TextBlock Text="Mes Serveurs" Style="{StaticResource TitleTextBlockStyle}"/>

            <Button Style="{StaticResource AccentButtonStyle}" Click="BtnAddServer_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <SymbolIcon Symbol="Add"/>
                    <TextBlock Text="Nouveau Serveur"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <GridView x:Name="ServerGrid" Grid.Row="1" Padding="24" SelectionMode="None">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:ServerModel">
                    <StackPanel Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" 
                                Padding="16" CornerRadius="8" Margin="0,0,16,16" Width="240" Spacing="8">

                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE7F4;" FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{ThemeResource SystemAccentColor}"/>
                            <TextBlock Text="{x:Bind Name}" FontWeight="Bold" FontSize="16"/>
                        </StackPanel>

                        <TextBlock Text="{x:Bind Host}" Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}"/>
                        <TextBlock Text="{x:Bind Username}" Opacity="0.6" Style="{StaticResource CaptionTextBlockStyle}"/>

                        <Button Content="Connecter" HorizontalAlignment="Stretch" Margin="0,8,0,0" Click="BtnConnect_Click"/>
                    </StackPanel>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <TextBlock x:Name="TxtEmpty" Grid.Row="1" Text="Aucun serveur. Ajoutez-en un !" 
                   HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5" Visibility="Collapsed"/>
    </Grid>
</Page>