<ContentDialog
    x:Class="WinBridge.App.Views.ServerEditDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Configurer le Serveur"
    PrimaryButtonText="Enregistrer"
    CloseButtonText="Annuler"
    DefaultButton="Primary">

    <Grid MinWidth="400">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. OS Category -->
        <ComboBox x:Name="OsCategoryCombo" Header="Type de serveur" HorizontalAlignment="Stretch" SelectionChanged="OsCategoryCombo_SelectionChanged" SelectedIndex="0" Margin="0,0,0,12">
            <ComboBoxItem Content="Linux" Tag="Linux"/>
            <ComboBoxItem Content="Windows" Tag="Windows"/>
        </ComboBox>

        <!-- 2. Essential Info -->
        <TextBox x:Name="NameBox" Grid.Row="1" Header="Nom du serveur" Margin="0,0,0,12"/>
        
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="HostBox" Header="Hôte (IP/DNS)" Margin="0,0,12,0"/>
            <NumberBox x:Name="SshPortBox" Grid.Column="1" Header="Port SSH" Value="22" SpinButtonPlacementMode="Compact" MinWidth="80"/>
        </Grid>

        <!-- 3. Auth -->
        <Grid Grid.Row="3" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="UserBox" Header="Utilisateur" Margin="0,0,12,0"/>
            <PasswordBox x:Name="PassBox" Grid.Column="1" Header="Mot de passe"/>
        </Grid>
        
        <!-- 4. Windows Specifics -->
        <StackPanel x:Name="WindowsSettingsPanel" Grid.Row="4" Visibility="Collapsed" 
                    Background="{ThemeResource LayerFillColorDefaultBrush}" Padding="12" CornerRadius="4" Margin="0,0,0,12">
            <TextBlock Text="Options Windows &amp; Hybrides" Style="{StaticResource BodyStrongTextBlockStyle}" Margin="0,0,0,12"/>
            
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="PrimaryProtocolCombo" Header="Protocole Principal" HorizontalAlignment="Stretch" SelectionChanged="PrimaryProtocolCombo_SelectionChanged" Margin="0,0,12,0">
                    <ComboBoxItem Content="SSH" Tag="SSH"/>
                    <ComboBoxItem Content="WinRM" Tag="WinRM"/>
                </ComboBox>
                <NumberBox x:Name="WinRmPortBox" Grid.Column="1" Header="Port WinRM" Value="5985" SpinButtonPlacementMode="Compact"/>
            </Grid>

            <TextBox x:Name="DomainBox" Header="Domaine (Optionnel)" Margin="0,0,0,12"/>
            
            <CheckBox x:Name="FallbackCheck" Content="Utiliser WinRM si SSH échoue" Margin="0,0,0,12"/>
            
            <InfoBar Severity="Informational" IsOpen="True" IsClosable="False" 
                     Title="Info WinRM" Message="WinRM nécessite 'winrm quickconfig' sur la cible." />
        </StackPanel>

        <!-- 5. Keys -->
        <ComboBox x:Name="KeyCombo" Grid.Row="5" Header="Clé SSH (Optionnel)" HorizontalAlignment="Stretch" DisplayMemberPath="Name"/>
    </Grid>
</ContentDialog>
