<Page
    x:Class="WinBridge.App.Views.KeysPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WinBridge.Models.Entities"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Padding="24" Orientation="Horizontal" Spacing="20">
            <TextBlock Text="Gestion des Clés SSH" Style="{StaticResource TitleTextBlockStyle}"/>

            <Button Style="{StaticResource AccentButtonStyle}" Click="BtnImport_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <SymbolIcon Symbol="Add"/>
                    <TextBlock Text="Importer une clé"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <ListView x:Name="KeysList" Grid.Row="1" Padding="24" SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:SshKeyModel">
                    <Grid Padding="12" CornerRadius="4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <FontIcon Glyph="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="24" Margin="0,0,16,0" Foreground="{ThemeResource SystemAccentColor}"/>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="{x:Bind DefaultUsername}" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.6"/>
                        </StackPanel>

                        <Button Grid.Column="2" Background="Transparent" BorderThickness="0" Click="BtnDelete_Click">
                            <SymbolIcon Symbol="Delete" Foreground="IndianRed"/>
                        </Button>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <TextBlock x:Name="TxtEmpty" Grid.Row="1" Text="Aucune clé configurée." 
                   HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5" Visibility="Collapsed"/>
    </Grid>
</Page>