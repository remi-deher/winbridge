<Page
    x:Class="WinBridge.App.Views.TerminalPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Black">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ScrollViewer x:Name="TerminalScroll" Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <TextBlock x:Name="TxtTerminalOutput" 
                       Padding="10"
                       FontFamily="Cascadia Code, Consolas, Monospace" 
                       FontSize="14" 
                       Foreground="LightGreen" 
                       TextWrapping="Wrap"/>
        </ScrollViewer>

        <TextBox x:Name="TxtInput" 
                 Grid.Row="1"
                 PlaceholderText="Tapez une commande et appuyez sur Entrée..."
                 KeyDown="TxtInput_KeyDown"
                 FontFamily="Cascadia Code, Consolas"
                 Background="#111"
                 Foreground="White"
                 BorderThickness="0,1,0,0"/>
    </Grid>
</Page>