<Page
    x:Class="WinBridge.App.Views.ExtensionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Extensions" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,20"/>

        <!-- Install Section -->
        <StackPanel Grid.Row="1" Spacing="10" Margin="0,0,0,30">
            <TextBlock Text="Installer une extension depuis GitHub" Style="{StaticResource SubtitleTextBlockStyle}"/>
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="GitHubUrlTextBox" PlaceholderText="https://github.com/user/repo" />
                <Button x:Name="InstallButton" Content="Installer" Grid.Column="1" Click="InstallButton_Click" Style="{StaticResource AccentButtonStyle}"/>
            </Grid>
            <ProgressBar x:Name="DownloadProgressBar" IsIndeterminate="False" Value="0" Visibility="Collapsed"/>
            <TextBlock x:Name="StatusTextBlock" Style="{StaticResource CaptionTextBlockStyle}"/>
        </StackPanel>
        
        <!-- Installed List -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Extensions Installées" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,10"/>
            
            <ListView x:Name="ExtensionsListView" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="{Binding GitHubUrl}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding Version}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>
